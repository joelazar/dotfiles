#!/bin/bash
# Managed by chezmoi — tracked settings are defined below.
# Local-only keys (see LOCAL_KEYS) are preserved from the existing file
# so churn in things like the changelog version / default model is ignored.

set -euo pipefail

# --- Tracked config (edit here) ---
MANAGED_CONFIG='{
  "hideThinkingBlock": true,
  "shellCommandPrefix": "shopt -s expand_aliases\nexport GIT_PAGER=cat PAGER=cat AWS_PAGER=\"\"\nalias python=python3",
  "collapseChangelog": false,
  "theme": "catppuccin-mocha",
  "doubleEscapeAction": "tree",
  "enabledModels": [
    "openai-codex/gpt-5.5",
    "anthropic/claude-opus-4-8"
  ],
  "showHardwareCursor": true,
  "quietStartup": true,
  "extensions": [],
  "packages": [
    "/Users/joelazar/Code/ai/pi/pi-review",
    "/Users/joelazar/Code/ai/pi/pi-nvim",
    "/Users/joelazar/Code/ai/pi/pi-packages/packages/pi-claude-code-use",
    "/Users/joelazar/Code/ai/pi/pi-packages/packages/pi-openai-fast",
    "/Users/joelazar/Code/ai/pi/pi-packages/packages/pi-openai-verbosity",
    "git:github.com/supabitapp/supaterm-skills"
  ],
  "transport": "auto",
  "treeFilterMode": "default",
  "steeringMode": "all",
  "followUpMode": "one-at-a-time",
  "warnings": {
    "anthropicExtraUsage": false
  },
  "enableInstallTelemetry": true,
  "terminal": {
    "showTerminalProgress": true
  }
}'

# Local-only keys — preserved from the existing file, never overwritten.
LOCAL_KEYS='["lastChangelogVersion", "defaultThinkingLevel", "defaultProvider", "defaultModel"]'

# --- Read existing file from stdin ---
EXISTING="$(cat)"

# Emit JSON without a trailing newline so we match how the pi app rewrites
# the file (it writes no final newline, which otherwise causes churn).
emit() {
  # shellcheck disable=SC2005
  printf '%s' "$(cat)"
}

# No existing file → just emit the managed config
if [ -z "$EXISTING" ] || ! echo "$EXISTING" | jq -e . >/dev/null 2>&1; then
  echo "$MANAGED_CONFIG" | jq . | emit
  exit 0
fi

# Merge: managed config + preserved local keys from the existing file
jq -n \
  --argjson managed  "$MANAGED_CONFIG" \
  --argjson existing "$EXISTING" \
  --argjson keys     "$LOCAL_KEYS" \
  '$managed + ($existing | with_entries(select(.key as $k | $keys | index($k))))' \
  | emit
