{{ if eq .type "work" -}}
#!/bin/bash
#
# Install the `gcx` Agent Skill bundled with the gcx CLI itself.
# Only the single `gcx` skill is installed (out of 18 bundled) — bump the
# list below to include more.
#
# Re-runs whenever this script content changes (script hash is stable
# unless we edit the SKILLS list or the gcx version).

set -euo pipefail

. "{{ joinPath .chezmoi.sourceDir "scripts/utils" }}"

GCX_SKILLS=(gcx)

if ! cmd_exists "gcx"; then
    show_message "⚠️  gcx CLI not installed; skipping gcx skill install." "$ORANGE"
    exit 0
fi

show_section "📊 Installing gcx Agent Skills (${GCX_SKILLS[*]})" "$CYAN"
gcx skills install "${GCX_SKILLS[@]}" --force
{{ else -}}
#!/bin/bash
# Non-work machine — gcx skills not installed.
exit 0
{{ end -}}
