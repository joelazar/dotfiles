#!/bin/bash
SOURCE_DIR=$(chezmoi source-path)

. "$SOURCE_DIR/scripts/utils_install" &&
    . "$SOURCE_DIR/scripts/utils"

echo "🧑‍💻 Updating Claude Code"
brew upgrade claude-code@latest
echo

echo "🚀 Update Codex"
brew upgrade codex
echo

echo "🥧 Update Pi"
pi update --self
echo

echo "🥧 Update Pi extensions"
"${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}/scripts/pi-packages-update"
echo

ask_for_confirmation "📊 Do you want to update gcx Agent Skills?"
if answer_is_yes; then
    gcx agent skills install --all --force
fi
