#!/usr/bin/env bash
#
# Back up selected dotfiles and configs to the restic repo in $RESTIC_REPOSITORY.
#
set -Eeuo pipefail

if [[ -z "${RESTIC_REPOSITORY:-}" ]]; then
    echo '❌ RESTIC_REPOSITORY is not set' >&2
    exit 1
fi

HELIUM_SUPPORT="$HOME/Library/Application Support/net.imput.helium"

INCLUDE=(
    "$HOME/.agents"
    "$HOME/.aws"
    "$HOME/.claude"
    "$HOME/.claude-work"
    "$HOME/.claude.json"
    "$HOME/.config"
    "$HOME/.docker/config.json"
    "$HOME/.gemini"
    "$HOME/.gnupg"
    "$HOME/.kube"
    "$HOME/.npmrc"
    "$HOME/.obsidian-headless"
    "$HOME/.pi"
    "$HOME/.ssh"
    "$HOME/.local/bin"
    "$HOME/.local/share/fish/fish_history"
    "$HOME/.local/share/atuin"
    "$HELIUM_SUPPORT"
    "$HOME/Library/Preferences/net.imput.helium.plist"
    "$HOME/Library/Application Support/com.tinyapp.TablePlus"
    "$HOME/Library/Preferences/com.tinyapp.TablePlus.plist"
)

# Helium is Chromium-based, so most of its support directory is regenerable
# cache/telemetry. Keep only the meaningful profile config by dropping the
# heavy, throwaway paths.
EXCLUDE=(
    "$HELIUM_SUPPORT/BrowserMetrics"
    "$HELIUM_SUPPORT/DeferredBrowserMetrics"
    "$HELIUM_SUPPORT/Crashpad"
    "$HELIUM_SUPPORT/CertificateRevocation"
    "$HELIUM_SUPPORT/GPUPersistentCache"
    "$HELIUM_SUPPORT/GraphiteDawnCache"
    "$HELIUM_SUPPORT/component_crx_cache"
    "$HELIUM_SUPPORT/Webstore Downloads"
    "$HELIUM_SUPPORT/Default/Service Worker"
    "$HELIUM_SUPPORT/Default/IndexedDB"
    "$HELIUM_SUPPORT/Default/File System"
    "$HELIUM_SUPPORT/Default/GPUCache"
    "$HELIUM_SUPPORT/Default/DawnWebGPUCache"
    "$HELIUM_SUPPORT/Default/DawnGraphiteCache"
    "$HELIUM_SUPPORT/Default/Cache"
    "$HELIUM_SUPPORT/Default/Code Cache"
)

ensure_repository_ready() {
    local volume
    volume="$(dirname "$RESTIC_REPOSITORY")"
    if [[ ! -d "$volume" ]]; then
        printf '❌ Backup volume "%s" is not mounted\n' "$volume" >&2
        exit 1
    fi
    if ! restic cat config >/dev/null 2>&1; then
        printf '📦 Initializing new restic repository at "%s"\n' "$RESTIC_REPOSITORY"
        restic init
    fi
}

run_backup() {
    printf '💾 Backing up to "%s"\n' "$RESTIC_REPOSITORY"
    restic unlock
    local exclude_args=()
    local path
    for path in "${EXCLUDE[@]}"; do
        exclude_args+=(--exclude "$path")
    done
    restic backup "${INCLUDE[@]}" \
        --retry-lock 3h \
        --compression max \
        --exclude-caches \
        "${exclude_args[@]}" \
        "$@"
}

ensure_repository_ready
run_backup "$@"
