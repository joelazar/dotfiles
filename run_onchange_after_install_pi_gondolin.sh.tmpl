#!/bin/bash
#
# Install dependencies for the pi Gondolin extension.
#
# The extension routes pi's built-in tools into a local Gondolin micro-VM and
# depends on @earendil-works/gondolin. node_modules is not tracked by chezmoi
# (see .chezmoiignore), so install it here on apply.
#
# Re-runs whenever the lockfile changes:
# package-lock.json hash: {{ include (joinPath .chezmoi.sourceDir "dot_pi/agent/extensions/gondolin/package-lock.json") | sha256sum }}

set -euo pipefail

. "{{ joinPath .chezmoi.sourceDir "scripts/utils" }}"

EXT_DIR="{{ .chezmoi.homeDir }}/.pi/agent/extensions/gondolin"

if ! cmd_exists "npm"; then
    show_message "⚠️  npm not installed; skipping Gondolin extension deps." "$ORANGE"
    exit 0
fi

if ! cmd_exists "qemu-system-aarch64" && ! cmd_exists "qemu-system-x86_64"; then
    show_message "⚠️  QEMU not installed; Gondolin needs it at runtime (brew install qemu)." "$ORANGE"
fi

show_section "📦 Installing pi Gondolin extension deps" "$CYAN"
( cd "$EXT_DIR" && npm install --ignore-scripts )
show_message "✓ Gondolin extension ready" "$GREEN"
