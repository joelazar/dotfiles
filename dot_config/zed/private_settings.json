{
  // ══════════════════════════════════════════════════════════════════════════════
  // APPEARANCE
  // ══════════════════════════════════════════════════════════════════════════════
  "debugger": {
    "button": false,
  },
  "search": {
    "button": false,
  },
  "toolbar": {
    "code_actions": false,
    "agent_review": true,
    "selections_menu": true,
    "quick_actions": false,
    "breadcrumbs": true,
  },
  "status_bar": {
    "show_active_file": false,
    "cursor_position_button": true,
    "active_language_button": true,
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Mocha",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Mocha",
    "dark": "Material Icon Theme",
  },
  "ui_font_size": 13.0,
  "agent_ui_font_size": 13.0,
  "buffer_font_size": 12.0,
  "buffer_font_family": "Maple Mono NF",
  "buffer_font_features": {
    "calt": true, // standard ligatures (-> => != etc)
    "cv02": true, // alternative `a` with top arm
    "cv05": true, // alternative `g` in double story style
    "cv61": true, // alternative `,` and `;` with straight tail
    "cv63": true, // alternative `<=` in arrow style
  },
  "cursor_blink": false,
  "colorize_brackets": true, // rainbow brackets
  "document_symbols": "on",
  "diff_view_style": "split",

  // ══════════════════════════════════════════════════════════════════════════════
  // EDITOR BEHAVIOR
  // ══════════════════════════════════════════════════════════════════════════════
  "vim_mode": true,
  "scroll_beyond_last_line": "off", // prevent scrolling past last line
  "vertical_scroll_margin": 0, // cursor can reach screen edges
  "preferred_line_length": 140,
  "double_click_in_multibuffer": "open", // double-click opens file instead of selecting
  "close_on_file_delete": true, // auto-close tabs when file deleted on disk
  "use_smartcase_search": true, // case-insensitive unless uppercase used

  // ══════════════════════════════════════════════════════════════════════════════
  // VIM SETTINGS
  // ══════════════════════════════════════════════════════════════════════════════
  "vim": {
    "use_system_clipboard": "never", // use vim registers, not system clipboard
    "use_smartcase_find": true, // case-insensitive find unless uppercase
    "highlight_on_yank_duration": 500, // visual feedback on yank (ms)
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // WHICH-KEY (shows keybinding hints after delay)
  // ══════════════════════════════════════════════════════════════════════════════
  "which_key": {
    "enabled": true,
    "delay_ms": 400,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // GIT INTEGRATION
  // ══════════════════════════════════════════════════════════════════════════════
  "git": {
    "inline_blame": {
      "delay_ms": 200,
      "show_commit_summary": true,
    },
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // INLAY HINTS & INDENT GUIDES
  // ══════════════════════════════════════════════════════════════════════════════
  "inlay_hints": {
    "enabled": true,
  },
  "indent_guides": {
    "coloring": "indent_aware", // different colors per indent level
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // PREVIEW TABS
  // ══════════════════════════════════════════════════════════════════════════════
  "preview_tabs": {
    "enabled": true,
    "enable_keep_preview_on_code_navigation": true,
    "enable_preview_from_file_finder": true,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // MULTIBUFFER / EXCERPTS (search results, references)
  // ══════════════════════════════════════════════════════════════════════════════
  "excerpt_context_lines": 3,
  "expand_excerpt_lines": 10,

  // ══════════════════════════════════════════════════════════════════════════════
  // SEARCH
  // ══════════════════════════════════════════════════════════════════════════════
  "seed_search_query_from_cursor": "selection", // only use selected text

  // ══════════════════════════════════════════════════════════════════════════════
  // SESSION
  // ══════════════════════════════════════════════════════════════════════════════
  "session": {
    "trust_all_worktrees": true,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // WINDOW & LAYOUT
  // ══════════════════════════════════════════════════════════════════════════════
  "use_system_window_tabs": true,
  "restore_on_startup": "launchpad",
  "bottom_dock_layout": "right_aligned",
  "centered_layout": {
    "left_padding": 0.15,
    "right_padding": 0.15,
  },
  "active_pane_modifiers": {
    "inactive_opacity": 0.7,
    "border_size": 0.5,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // TITLE BAR
  // ══════════════════════════════════════════════════════════════════════════════
  "title_bar": {
    "show_branch_status_icon": true,
    "show_user_picture": false,
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_branch_name": true,
    "show_user_menu": true,
    "show_menus": true,
    "show_sign_in": false,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // TAB BAR & TABS
  // ══════════════════════════════════════════════════════════════════════════════
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "tabs": {
    "show_diagnostics": "errors",
    "git_status": true,
    "file_icons": true,
    "activate_on_close": "neighbour",
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // SCROLLBAR
  // ══════════════════════════════════════════════════════════════════════════════
  "scrollbar": {
    "show": "system",
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // PANELS
  // ══════════════════════════════════════════════════════════════════════════════
  "project_panel": {
    "dock": "right",
    "button": false,
    "default_width": 300,
    "auto_fold_dirs": false,
    "auto_reveal_entries": false,
    "entry_spacing": "standard",
    "diagnostic_badges": true,
    "git_status_indicator": true, // show git status colors on files in project panel
  },
  "outline_panel": {
    "button": false,
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
    "button": false,
    "default_width": 300,
  },
  "git_panel": {
    "dock": "right",
    "button": false,
    "tree_view": true,
    "sort_by_path": true,
    "default_width": 300,
    "show_count_badge": true,
    "file_icons": true,
    "status_style": "icon", // show git status as icons (alternative: "label_color")
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // FILE FINDER
  // ══════════════════════════════════════════════════════════════════════════════
  "file_finder": {
    "modal_max_width": "medium",
    "include_ignored": "all",
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // DIAGNOSTICS
  // ══════════════════════════════════════════════════════════════════════════════
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // MESSAGES & CALLS
  // ══════════════════════════════════════════════════════════════════════════════
  "message_editor": {
    "auto_replace_emoji_shortcode": false,
  },
  "calls": {
    "mute_on_join": true,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // AI / EDIT PREDICTIONS
  // ══════════════════════════════════════════════════════════════════════════════
  // ══════════════════════════════════════════════════════════════════════════════
  // AGENT (AI Assistant)
  // ══════════════════════════════════════════════════════════════════════════════
  "edit_predictions": {
    "disabled_globs": [],
    "provider": "zed",
  },
  "agent": {
    "sidebar_side": "left",
    "dock": "left",
    "max_content_width": 1200.0,
    "button": false,
    "single_file_review": false,
    "tool_permissions": {
      "default": "allow",
    },
    "message_editor_min_lines": 3,
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
    },
    "use_modifier_to_send": false,
    "play_sound_when_agent_done": "never",
    "show_turn_stats": true, // show timer + token count per turn
    "commit_message_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.4-mini",
    },
    "enable_feedback": false,
    "thinking_display": "preview",
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
    },
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // AGENT SERVERS (external AI agents)
  // ══════════════════════════════════════════════════════════════════════════════
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
      "default_mode": "full-access",
    },
    "claude-acp": {
      "type": "registry",
      "default_mode": "bypassPermissions",
      "favorite_models": ["opus", "default"],
    },
    "pi-acp": {
      "type": "registry",
    },
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // SSH CONNECTIONS
  // ══════════════════════════════════════════════════════════════════════════════
  "ssh_connections": [
    {
      "host": "joes-macbook-workstation",
      "username": "joelazar",
      "args": [],
      "projects": [
        {
          "paths": ["/Users/joelazar/Code/jets"],
        },
      ],
    },
    {
      "host": "openclaw",
      "username": "openclaw",
      "args": [],
      "projects": [
        {
          "paths": ["/home/openclaw"],
        },
      ],
    },
  ],

  // ══════════════════════════════════════════════════════════════════════════════
  // TERMINAL
  // ══════════════════════════════════════════════════════════════════════════════
  "terminal": {
    "button": false,
    "scrollbar": {
      "show": "never",
    },
    "max_scroll_history_lines": 50000,
    "blinking": "off",
    "font_family": "Maple Mono NF",
    "font_features": {
      "calt": true,
      "cv02": true,
      "cv05": true,
      "cv61": true,
      "cv63": true,
    },
    "detect_venv": {
      "on": {
        "activate_script": "fish",
      },
    },
    "env": {
      "GIT_EDITOR": "zed --wait",
      "EDITOR": "zed",
    },
    "minimum_contrast": 0,
    "keep_selection_on_copy": false,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // DIRENV
  // ══════════════════════════════════════════════════════════════════════════════
  "load_direnv": "shell_hook",

  // ══════════════════════════════════════════════════════════════════════════════
  // READ-ONLY FILES (prevent accidental edits)
  // ══════════════════════════════════════════════════════════════════════════════
  "read_only_files": ["**/*.lock", "**/vendor/**", "**/node_modules/**"],

  // ══════════════════════════════════════════════════════════════════════════════
  // FILE SCAN EXCLUSIONS (performance)
  // ══════════════════════════════════════════════════════════════════════════════
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/.vscode",
    "**/.idea",
    "**/.serverless",
    "**/build",
    "**/dist",
    "**/coverage",
    "**/.venv",
    "**/__pycache__",
    "**/.ropeproject",
    "**/.pytest_cache",
    "**/.ruff_cache",
  ],

  // ══════════════════════════════════════════════════════════════════════════════
  // FILE TYPE ASSOCIATIONS
  // ══════════════════════════════════════════════════════════════════════════════
  "file_types": {
    "Ansible": [
      "**.ansible.yml",
      "**/defaults/**.yml",
      "**/defaults/**.yaml",
      "**/meta/**.yml",
      "**/meta/**.yaml",
      "**/tasks/**.yml",
      "**/tasks/*.yml",
      "**/tasks/*.yaml",
      "**/handlers/*.yml",
      "**/handlers/*.yaml",
      "**/group_vars/**.yml",
      "**/group_vars/**.yaml",
      "**playbook*.yaml",
      "**playbook*.yml",
    ],
    "Dockerfile": ["Dockerfile*"],
    "Helm": [
      "**/templates/**/*.tpl",
      "**/templates/**/*.yaml",
      "**/templates/**/*.yml",
      "**/helmfile.d/**/*.yaml",
      "**/helmfile.d/**/*.yml",
      "**/values*.yaml",
    ],
    "Shell Script": ["*.envrc*"],
    "Nginx": ["**/nginx/**/*.conf", "nginx.conf"],
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // LANGUAGE MODELS
  // ══════════════════════════════════════════════════════════════════════════════
  "language_models": {},

  // ══════════════════════════════════════════════════════════════════════════════
  // LSP CONFIGURATIONS
  // ══════════════════════════════════════════════════════════════════════════════
  "lsp": {
    // Rust: use clippy, enable all features and proc macros
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
        "cargo": {
          "allFeatures": true,
          "loadOutDirsFromCheck": true,
          "buildScripts": {
            "enable": true,
          },
        },
        "procMacro": {
          "enable": true,
          "ignored": {
            "async-trait": ["async_trait"],
            "napi-derive": ["napi"],
            "async-recursion": ["async_recursion"],
          },
        },
        "rust": {
          "analyzerTargetDir": true,
        },
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "closureReturnTypeHints": {
            "enable": "always",
          },
        },
      },
    },
    // Python: basedpyright with relaxed type checking
    "basedpyright": {
      "settings": {
        "python": {
          "pythonPath": ".venv/bin/python",
          "analysis": {
            "diagnosticSeverityOverrides": {
              "reportAny": "none",
              "reportMissingParameterType": "none",
              "reportMissingTypeArgument": "none",
              "reportMissingTypeStubs": "none",
              "reportUnknownArgumentType": "none",
              "reportUnknownLambdaType": "none",
              "reportUnknownMemberType": "none",
              "reportUnknownParameterType": "none",
              "reportUnknownVariableType": "none",
            },
          },
        },
      },
    },
    // Ansible: lint enabled
    "ansible": {
      "settings": {
        "ansible": {
          "path": "ansible",
        },
        "executionEnvironment": {
          "enabled": false,
        },
        "python": {
          "interpreterPath": "python3",
        },
        "validation": {
          "enabled": true,
          "lint": {
            "enabled": true,
            "path": "ansible-lint",
          },
        },
      },
    },
    // Go: gofumpt, semantic tokens, codelenses, hints
    "gopls": {
      "initialization_options": {
        "gofumpt": true,
        "usePlaceholders": false,
        "completeUnimported": true,
        "staticcheck": false,
        "semanticTokens": true,
        "directoryFilters": ["-.git", "-.vscode", "-.idea", "-.vscode-test", "-node_modules"],
        "experimentalPostfixCompletions": true,
        "ui.codelenses": {
          "gc_details": true,
        },
        "ui.diagnostic.annotations": {
          "escape": true,
          "inline": true,
          "bounds": true,
          "nil": true,
        },
        "codelenses": {
          "gc_details": true,
          "generate": true,
          "regenerate_cgo": true,
          "run_govulncheck": true,
          "test": true,
          "tidy": true,
          "upgrade_dependency": true,
          "vendor": true,
        },
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
        "analyses": {
          "nilness": true,
          "unusedparams": true,
          "unusedwrite": true,
          "useany": true,
        },
      },
    },
    // golangci-lint
    "golangci-lint": {
      "initialization_options": {
        "command": ["golangci-lint", "run", "--output.json.path", "stdout", "--show-stats=false", "--output.text.path="],
      },
    },
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // LANGUAGE-SPECIFIC SETTINGS
  // ══════════════════════════════════════════════════════════════════════════════
  "languages": {
    "Python": {
      "format_on_save": "on",
      "formatter": [
        {
          "external": {
            "command": "bash",
            "arguments": ["-c", "ruff check --select=I --fix --stdin-filename {buffer_path} | ruff format --stdin-filename {buffer_path}"],
          },
        },
      ],
      "language_servers": ["ty", "..."],
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "Go": {
      "format_on_save": "on",
      "language_servers": ["!harper-ls", "..."],
      "document_folding_ranges": "on",
    },
    "Markdown": {
      "format_on_save": "on",
    },
    "Terraform": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "tofu",
          "arguments": ["fmt", "-"],
        },
      },
    },
    "Fish": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "fish_indent",
          "arguments": [],
        },
      },
    },
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // AUTO-INSTALL EXTENSIONS
  // ══════════════════════════════════════════════════════════════════════════════
  "auto_install_extensions": {
    "ansible": true,
    "basher": true,
    "catppuccin": true,
    "catppuccin-blur": true,
    "catppuccin-icons": true,
    "csv": true,
    "docker-compose": true,
    "dockerfile": true,
    "env": true,
    "fish": true,
    "git-firefly": true,
    "github-actions": true,
    "go-snippets": true,
    "golangci-lint": true,
    "harper": true,
    "helm": true,
    "html": true,
    "kanagawa-themes": true,
    "latex": true,
    "log": true,
    "lua": true,
    "make": true,
    "markdown-oxide": true,
    "material-icon-theme": true,
    "nginx": true,
    "nix": true,
    "prisma": true,
    "scheme": true,
    "sql": true,
    "terraform": true,
    "toml": true,
    "vscode-icons": true,
    "zedokai": true,
    "zig": true,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // THEME OVERRIDES (empty - using defaults)
  // ══════════════════════════════════════════════════════════════════════════════
  "theme_overrides": {
    "Catppuccin Mocha": {
      "syntax": {
        "comment": {
          "font_style": "italic",
          "font_weight": 300,
        },
        "keyword": {
          "font_style": "italic",
        },
        "keyword.import": {
          "font_style": "italic",
        },
        "keyword.type": {
          "font_style": "italic",
        },
        "type": {
          "font_style": "italic",
        },
      },
    },
  },
}
